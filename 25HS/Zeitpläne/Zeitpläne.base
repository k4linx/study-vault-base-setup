views:
  - type: table
    name: Table
    filters:
      and:
        - file.ext == "md"
        - file.folder.contains("Zeitpläne")
        - Zeitplandatum >= "2026-01-02"
    order:
      - Zeitplandatum
      - file.name
      - erstelldatum
    columnSize:
      file.name: 142
  - type: cards
    name: View
    filters:
      and:
        - file.ext == "md"
        - file.folder.contains("Zeitpläne")
    order:
      - file.name
